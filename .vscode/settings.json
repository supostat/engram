{
  "workbench.iconTheme": "file-icons",
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.lineHeight": 1.3,
  "editor.fontFamily": "FiraCode-Retina",
  "editor.fontSize": 14,
  "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'zero', 'onum'",
  "workbench.colorTheme": "Atom One Dark",
  "terminal.integrated.fontSize": 14,
  "editor.tabSize": 2,
  "editor.showUnused": true,
  "git.autofetch": true,
  "files.eol": "\n",
  "editor.bracketPairColorization.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": false,
  "editor.snippetSuggestions": "top",
  "rubyLsp.rubyVersionManager": {
    "identifier": "rbenv"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never",
    "editor.formatOnSave": "never"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": false
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": false
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": false
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": false
  },
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": false,
    "editor.formatOnType": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true
  },
  "files.associations": {
    "Fastfile": "ruby",
    "*.js": "javascriptreact",
    "*.rb": "ruby"
  },
  "js/ts.updateImportsOnFileMove.enabled": "never",
  "files.insertFinalNewline": true,
  "editor.formatOnSaveMode": "file",
  "js/ts.validate.enabled": true,
  "editor.largeFileOptimizations": false,
  "editor.suggestSelection": "first",
  "files.exclude": {
    "**/.trunk/*out": true
  },
  "workbench.startupEditor": "none",
  "editor.foldingMaximumRegions": 10000,
  "git.ignoreMissingGitWarning": true,
  "files.trimTrailingWhitespace": true,
  "editor.rulers": [120],
  "files.watcherExclude": {
    "**/.trunk/*out": true
  },
  "window.zoomLevel": 1,
  "workbench.editorLargeFileConfirmation": 8000,
  "rubyLsp.enabledFeatures": {
    "documentHighlights": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "selectionRanges": true,
    "semanticHighlighting": true,
    "formatting": true,
    "diagnostics": true,
    "codeActions": true,
    "completion": true,
    "codeLens": true,
    "definition": true,
    "workspaceSymbol": true,
    "signatureHelp": true,
    "typeHierarchy": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "documentLink": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "makefile.configureOnOpen": false
}
